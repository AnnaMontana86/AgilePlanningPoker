# Copy to .env and adjust values

# Room expiry (hours, default 3)
ROOM_TTL_HOURS=3

# How often to check for expired rooms (seconds, default 60)
EXPIRY_CHECK_INTERVAL_SECONDS=60

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost

# Port to expose the app on (default 80)
APP_PORT=80
